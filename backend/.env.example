# PROJECT ODIN — copy to .env in this directory or odin/.env

GEMINI_API_KEY=your_key_here
# OPENAI_API_KEY=sk-...

ODIN_RUNTIME_MODE=development
ODIN_KERNEL_ENABLED=true

ODIN_MODEL_PRIMARY=gemini
ODIN_MODEL_FALLBACK=deepseek-r1
ODIN_MODEL_CODER=deepseek-coder

ODIN_LOCAL_MODELS_ENABLED=true
ODIN_OLLAMA_URL=http://localhost:11434

ODIN_LIVE_LOOP_ENABLED=false
ODIN_LIVE_LOOP_INTERVAL_SECONDS=5.0
ODIN_CONSCIOUS_LOOP_ENABLED=false

ODIN_AUTONOMY_LEVEL=1
ODIN_DESKTOP_CONTROL_ENABLED=false

ODIN_SIGNAL_BUS_ENABLED=true
ODIN_STABILITY_LOOP_ENABLED=true

ODIN_VALKYRIE_ENABLED=false

ODIN_DEBUG=false
ODIN_API_HOST=127.0.0.1
ODIN_API_PORT=8000
ODIN_REDIS_URL=redis://127.0.0.1:6379/0
ODIN_LOG_LEVEL=INFO
