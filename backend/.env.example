ODIN_RUNTIME_COORDINATION_ENABLED=1
ODIN_COGNITIVE_STATE_ENABLED=1
ODIN_GLOBAL_COGNITION_PROFILE=balanced

# Autonomous overnight cognition (v0.53)
ODIN_DEFERRED_REASONING_ENABLED=1
ODIN_CONTINUITY_FORECASTING_ENABLED=1
ODIN_MORNING_BRIEFING_ENABLED=1
ODIN_COGNITIVE_MAINTENANCE_ENABLED=1
ODIN_IDLE_ENGINEERING_ENABLED=1
