# Native autonomous desktop (v0.54)
ODIN_NATIVE_DESKTOP_ENABLED=1
ODIN_WINDOW_AWARENESS_ENABLED=1
ODIN_LIVE_OVERLAYS_V2_ENABLED=1
ODIN_WORKSPACE_SESSIONS_ENABLED=1
