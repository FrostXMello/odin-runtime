{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://127.0.0.1:8000/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/executions/[id]",
      "regex": "^/executions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/executions/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/missions/[id]",
      "regex": "^/missions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/missions/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/tasks/[id]",
      "regex": "^/tasks/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/tasks/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/traces/[id]",
      "regex": "^/traces/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/traces/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/diagnostics",
      "regex": "^/diagnostics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/diagnostics(?:/)?$"
    },
    {
      "page": "/executions",
      "regex": "^/executions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/executions(?:/)?$"
    },
    {
      "page": "/graph",
      "regex": "^/graph(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/graph(?:/)?$"
    },
    {
      "page": "/memory",
      "regex": "^/memory(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/memory(?:/)?$"
    },
    {
      "page": "/missions",
      "regex": "^/missions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/missions(?:/)?$"
    },
    {
      "page": "/runtime",
      "regex": "^/runtime(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/runtime(?:/)?$"
    },
    {
      "page": "/traces",
      "regex": "^/traces(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/traces(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}